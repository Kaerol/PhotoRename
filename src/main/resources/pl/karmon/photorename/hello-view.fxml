<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="375.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pl.karmon.photorename.HelloController">
    <top>
        <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <children>
                <ImageView fx:id="windowIcon" fitHeight="53.0" fitWidth="53.0" pickOnBounds="true" preserveRatio="true" HBox.hgrow="ALWAYS">
               <HBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </HBox.margin></ImageView>
                <VBox prefHeight="228.0" prefWidth="488.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label maxWidth="1.7976931348623157E308" text="Zamień nazwę" VBox.vgrow="ALWAYS">
                            <font>
                                <Font size="24.0" />
                            </font>
                        </Label>
                        <Label text="Zmienia nazwe zdjęcia na podstawie Metadanej Creationdate - zapisanych w pliku" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>
    <center>
        <GridPane BorderPane.alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints fillWidth="false" halignment="LEFT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints fillHeight="false" maxHeight="1.7976931348623157E308" minHeight="10.0" prefHeight="10.0" valignment="CENTER" vgrow="SOMETIMES" />
            <RowConstraints fillHeight="false" maxHeight="1.7976931348623157E308" minHeight="10.0" prefHeight="10.0" valignment="CENTER" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <TextField fx:id="sourceFolder" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" />
                <Button contentDisplay="RIGHT" mnemonicParsing="false" onMouseClicked="#onSelectSourceFolder" text="Wybierz" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER" />
                <TextField fx:id="destinationFolder" GridPane.hgrow="ALWAYS" GridPane.rowIndex="3" />
                <Button alignment="BOTTOM_CENTER" mnemonicParsing="false" onMouseClicked="#onSelectDestinationFolder" text="Wybierz" textAlignment="JUSTIFY" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="3" GridPane.valignment="CENTER" />
                <HBox prefHeight="17.0" prefWidth="500.0" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.valignment="CENTER">
                    <children>
                        <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Katalog źródłowy" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <HBox prefHeight="100.0" prefWidth="200.0" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER">
                    <children>
                        <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Katalog wynikowy" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            <ProgressBar fx:id="progressBar" maxWidth="1.7976931348623157E308" nodeOrientation="LEFT_TO_RIGHT" progress="0.0" GridPane.rowIndex="4" />
            <Label fx:id="errorShow" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" textFill="RED" GridPane.rowIndex="5">
               <padding>
                  <Insets left="2.0" />
               </padding>
               <font>
                  <Font name="System Bold Italic" size="12.0" />
               </font>
            </Label>
            </children>
        </GridPane>
    </center>
    <bottom>
        <ButtonBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <buttons>
                <Button defaultButton="true" onAction="#onRenamePhotos" text="Zmień" textAlignment="CENTER" />
                <Button mnemonicParsing="false" onAction="#onExit" text="Zamknij" />
            </buttons>
            <BorderPane.margin>
                <Insets />
            </BorderPane.margin>
        </ButtonBar>
    </bottom>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</BorderPane>
